generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactEnquiry {
  id        String   @id @default(cuid())
  name      String
  company   String?
  role      String?
  postcode  String?
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}
